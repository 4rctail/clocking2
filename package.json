{
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "express": "^4.19.2",
    "node-fetch": "^3.3.2",
    "dotenv": "^16.4.5"
  },
  "name": "clocking-bot",
  "version": "1.0.0",
  "scripts": {
    "build:win": "pkg package.json --targets node18-win-x64 --output dist/clocking-bot.exe",
    "checksum:win": "node scripts/generate-checksum.js dist/clocking-bot.exe release/latest.json",
    "release:local": "npm run build:win && npm run checksum:win"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "pkg-entry.cjs",
      "index.js",
      "keepAlive.js",
      "voiceGuard.js",
      "deploy-commands.js",
      "commands/**/*.js"
    ],
    "assets": [
      "*.json"
    ]
  },
  "bin": "pkg-entry.cjs",
  "main": "index.js"
}
